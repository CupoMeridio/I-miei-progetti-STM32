/* USER CODE BEGIN 1 */
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim) {
	if (htim->Instance == TIM6) {
		HAL_GPIO_TogglePin(GPIOA, Led_red_Pin);
	}
	if (htim->Instance == TIM7) {
		HAL_GPIO_TogglePin(GPIOA, Led_yellow_Pin);
	}
	if (htim->Instance == TIM16) {
		HAL_GPIO_TogglePin(GPIOA, Led_green_Pin);
	}
	if (htim->Instance == TIM17) {
		HAL_GPIO_TogglePin(GPIOA, Led_blu_Pin);
	}
}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin) {

	// --- GESTIONE ON ---
	if (GPIO_Pin == Button_on_Pin) {
		HAL_TIM_Base_Start_IT(&htim6);
		HAL_TIM_Base_Start_IT(&htim7);
		HAL_TIM_Base_Start_IT(&htim16);
	}

	// --- GESTIONE OFF ---
	else if (GPIO_Pin == Button_off_Pin) {
		HAL_TIM_Base_Stop_IT(&htim6);
		HAL_TIM_Base_Stop_IT(&htim7);
		HAL_TIM_Base_Stop_IT(&htim16);
	}

	// --- AUMENTA VELOCITÀ (Diminuisce ARR) ---
	else if (GPIO_Pin == Button_speed_up_Pin) {
		uint32_t current_arr = __HAL_TIM_GET_AUTORELOAD(&htim17);
		if (current_arr > TIMER_STEP + MIN_ARR) {
			__HAL_TIM_SET_AUTORELOAD(&htim17, current_arr - TIMER_STEP);
		}
	}

	// --- DIMINUISCE VELOCITÀ (Aumenta ARR) ---
	else if (GPIO_Pin == Button_speed_down_Pin) {
		uint32_t current_arr = __HAL_TIM_GET_AUTORELOAD(&htim17);
		if (current_arr < (65535 - TIMER_STEP)) {
			__HAL_TIM_SET_AUTORELOAD(&htim17, current_arr + TIMER_STEP);
		}
	}
}
